@model Hassann_Khala.Application.DTOs.Reports.MovementDetailsDto

@if (Model == null || !Model.Groups.Any())
{
    <div class="alert alert-info">No data found for selected filters.</div>
}
else
{
    foreach (var g in Model.Groups)
    {
        <div class="card mb-3">
            <div class="card-header">
                <strong>@g.GroupName</strong>
                <span class="float-end">Incoming: @g.TotalIncoming - Outgoing: @g.TotalOutgoing - Net: @g.Net</span>
            </div>
            <div class="card-body">
                <table class="table table-sm table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Product</th>
                            <th>Type</th>
                            <th>Qty</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var idx = 1; }
                        @foreach (var m in g.Movements)
                        {
                            <tr>
                                <td>@idx++</td>
                                <td>@m.ProductName</td>
                                <td>@m.MovementType</td>
                                <td>@m.Quantity</td>
                                <td>@m.Date.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="mt-3">
        <h5>Totals: Incoming: @Model.TotalIncoming - Outgoing: @Model.TotalOutgoing - Net: @Model.Net</h5>
    </div>
}
