@model IEnumerable<Hassann_Khala.Domain.Outbound>
@{
    ViewData["Title"] = "Outbound";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h5 mb-0">المبيعات</h2>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary d-md-none" href="#" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar"><i class="bi bi-list"></i></a>
        <a class="btn btn-primary" href="/Outbound/Create">اذن مبيعات جديد</a>
        <button class="btn btn-outline-dark toggle-dark d-none d-md-inline">
            <i class="bi bi-moon"></i>
        </button>
    </div>
</div>
<table class="table table-striped table-hover table-bordered align-middle mb-0">
    <thead>
        <tr>
            <th>العميل</th>
            <th>تاريخ الإنشاء</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach(var o in Model) {
        <tr>
            <td>@(o.Client != null ? o.Client.Name : o.ClientId.ToString())</td>
            <td>@o.CreatedAt.ToLocalTime().ToString("g")</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@o.Id">تفاصيل / طباعة</a>
            </td>
        </tr>
    }
    </tbody>
</table>