@{
    ViewData["Title"] = "Section Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>تقارير العنابر</h3>
        <div>
            <button id="btnToday" class="btn btn-outline-primary btn-sm">اليوم</button>
        </div>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-md-4">
            <label class="form-label">من</label>
            <input type="date" id="fromDate" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">الي</label>
            <input type="date" id="toDate" class="form-control" />
        </div>
        <div class="col-md-4 d-flex align-items-end gap-2">
            <button id="btnRange" class="btn btn-outline-primary">عرض الفترة</button>
            <button id="btnDay" class="btn btn-outline-secondary">يوم محدد</button>
            <button id="btnMonth" class="btn btn-outline-secondary">هذا الشهر</button>
        </div>
    </div>

    <div id="results">
        <div class="text-muted">لا توجد نتائج بعد</div>
    </div>
</div>

@section Scripts {
    <script>
        function load(mode, opts) {
            const qs = new URLSearchParams(Object.assign({ mode: mode }, opts || {}));
            fetch('/Reports/SectionFetch?' + qs.toString())
                .then(r => {
                    if (!r.ok) throw new Error('Server error');
                    return r.text();
                })
                .then(html => {
                    document.getElementById('results').innerHTML = html;
                })
                .catch(e => {
                    document.getElementById('results').innerHTML = '<div class="alert alert-danger">' + e.message + '</div>';
                });
        }

        document.getElementById('btnToday').addEventListener('click', function() { load('today'); });
        document.getElementById('btnRange').addEventListener('click', function() {
            const from = document.getElementById('fromDate').value;
            const to = document.getElementById('toDate').value;
            if (!from || !to) { alert('اختر تاريخين'); return; }
            load('range', { from: from, to: to });
        });
        document.getElementById('btnDay').addEventListener('click', function() {
            const d = document.getElementById('fromDate').value;
            if (!d) { alert('اختر يوم'); return; }
            load('day', { day: d });
        });
        document.getElementById('btnMonth').addEventListener('click', function() { load('month'); });
    </script>
}
