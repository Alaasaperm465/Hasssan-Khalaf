@model IEnumerable<MVC.ViewModels.Reports.IssuanceCardVM>

<div class="row row-cols-1 row-cols-md-2 g-3">
@foreach(var c in Model)
{
    <div class="col">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <div class="fw-bold">@((c.Type == "Inbound") ? "أذن إيداع" : "أذن صرف") #@c.Id</div>
                        <div class="text-muted small">@c.ClientName — @c.CreatedAt.ToLocalTime().ToString("g")</div>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold">Cartons: @c.TotalCartons</div>
                        <div class="fw-bold">Pallets: @c.TotalPallets</div>
                    </div>
                </div>

                <hr />
                <div>
                    @foreach(var l in c.Lines)
                    {
                        <div class="d-flex justify-content-between small mb-1">
                            <div>@l.ProductName</div>
                            <div>@l.Cartons × كرتون — @l.Pallets × بالت</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
</div>
