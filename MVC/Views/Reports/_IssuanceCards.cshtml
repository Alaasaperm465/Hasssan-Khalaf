@model IEnumerable<MVC.ViewModels.Reports.IssuanceCardVM>

<div class="row row-cols-1 row-cols-md-2 g-3">
@foreach(var c in Model)
{
    <div class="col">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <div class="fw-bold">@((c.Type == "Inbound") ? "اذن صرف" : "اذن استلام") #@c.Id</div>
                        <div class="text-muted small">@c.ClientName — @c.CreatedAt.ToLocalTime().ToString("g")</div>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold">عدد الكرتون: @c.TotalCartons</div>
                        <div class="fw-bold">عدد البالتات: @c.TotalPallets</div>
                    </div>
                </div>

                <hr />
                <div>
                    @foreach(var l in c.Lines)
                    {
                        <div class="d-flex justify-content-between small mb-1">
                            <div>@l.ProductName</div>
                            <div>@l.Cartons × كرتونة — @l.Pallets × بالتة</div>
                        </div>
                    }
                </div>
            </div>
            <div class="card-footer text-end">
                @if (c.Type == "Inbound")
                {
                    <a class="btn btn-sm btn-outline-primary" asp-controller="Inbound" asp-action="Details" asp-route-id="@c.Id">تفاصيل</a>
                }
                else
                {
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Outbound" asp-action="Details" asp-route-id="@c.Id">تفاصيل</a>
                }
            </div>
        </div>
    </div>
}
</div>
