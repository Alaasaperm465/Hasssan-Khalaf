@model MVC.ViewModels.Accounts.AccountDetailsVM
@{
    ViewData["Title"] = "Account Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --success-gradient: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%);
        --info-gradient: linear-gradient(135deg, #a1c4fd 0%, #c2e9fb 100%);
        --warning-gradient: linear-gradient(135deg, #fbc2eb 0%, #a6c1ee 100%);
        --danger-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }

    .stat-card {
        border: none;
        border-radius: 15px;
        transition: all 0.3s ease;
        background: white;
        overflow: hidden;
        position: relative;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--primary-gradient);
        }

        .stat-card.primary::before {
            background: var(--primary-gradient);
        }

        .stat-card.success::before {
            background: var(--success-gradient);
        }

        .stat-card.info::before {
            background: var(--info-gradient);
        }

        .stat-card.danger::before {
            background: var(--danger-gradient);
        }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(102, 126, 234, 0.1);
        color: #667eea;
        font-size: 2rem;
    }

    .stat-card.primary .stat-icon {
        background: rgba(102, 126, 234, 0.1);
        color: #667eea;
    }

    .stat-card.success .stat-icon {
        background: rgba(132, 250, 176, 0.1);
        color: #84fab0;
    }

    .stat-card.info .stat-icon {
        background: rgba(161, 196, 253, 0.1);
        color: #a1c4fd;
    }

    .stat-card.danger .stat-icon {
        background: rgba(240, 147, 251, 0.1);
        color: #f093fb;
    }

    .stat-value {
        font-size: 2.5rem;
        font-weight: 700;
        line-height: 1.2;
        color: #2c3e50;
    }

    .stat-label {
        font-size: 0.9rem;
        color: #7f8c8d;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .main-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        overflow: hidden;
        background: white;
    }

    .card-header-custom {
        background: white;
        border-bottom: 2px solid #f8f9fa;
        padding: 1.5rem;
    }

    .profile-header {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        border: none;
        margin-bottom: 2rem;
        overflow: hidden;
        position: relative;
    }

        .profile-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--primary-gradient);
        }

    .profile-avatar {
        width: 70px;
        height: 70px;
        background: var(--primary-gradient);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: white;
        box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
    }

    .profile-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 0.25rem;
    }

    .profile-subtitle {
        color: #7f8c8d;
        font-size: 1rem;
    }

    .btn-back {
        border-radius: 50px;
        padding: 0.6rem 1.8rem;
        font-weight: 500;
        border: 2px solid #eef2f6;
        color: #7f8c8d;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-back:hover {
            background: #f8f9fa;
            border-color: #667eea;
            color: #667eea;
            transform: translateX(-5px);
        }

    .info-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        overflow: hidden;
        background: white;
        height: 100%;
        transition: all 0.3s ease;
    }

        .info-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        }

    .info-card-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 1rem 1.5rem;
        color: white;
    }

        .info-card-header h6 {
            margin: 0;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

    .info-card-body {
        padding: 1.5rem;
    }

    .info-item {
        display: flex;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #eef2f6;
    }

        .info-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

    .info-item-label {
        width: 100px;
        color: #7f8c8d;
        font-weight: 500;
    }

    .info-item-value {
        flex: 1;
        color: #2c3e50;
        font-weight: 600;
    }

    .stats-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        overflow: hidden;
        background: white;
    }

    .stats-card-header {
        background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%);
        padding: 1rem 1.5rem;
        color: #2c3e50;
    }

        .stats-card-header h6 {
            margin: 0;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

    .stats-card-body {
        padding: 1.5rem;
    }

    .stat-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 0;
        border-bottom: 1px solid #eef2f6;
    }

        .stat-row:last-child {
            border-bottom: none;
        }

    .stat-row-label {
        color: #7f8c8d;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .stat-row-value {
        font-weight: 700;
        color: #2c3e50;
        font-size: 1.2rem;
    }

    .stat-row.total {
        margin-top: 0.5rem;
        padding-top: 1rem;
        border-top: 2px solid #eef2f6;
        border-bottom: none;
    }

        .stat-row.total .stat-row-label {
            font-weight: 700;
            color: #2c3e50;
        }

        .stat-row.total .stat-row-value {
            font-size: 1.4rem;
            color: #667eea;
        }

    .transactions-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        overflow: hidden;
        background: white;
    }

    .transactions-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 1rem 1.5rem;
        color: white;
    }

        .transactions-header h6 {
            margin: 0;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 1.1rem;
        }

    .table-custom {
        margin-bottom: 0;
    }

        .table-custom thead th {
            background: #f8faff;
            color: #2c3e50;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid #eef2f6;
            padding: 1rem;
        }

        .table-custom tbody tr {
            transition: all 0.3s ease;
            border-bottom: 1px solid #eef2f6;
        }

            .table-custom tbody tr:hover {
                background: #f8faff;
                transform: scale(1.01);
                box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            }

        .table-custom td {
            padding: 1rem;
            vertical-align: middle;
            color: #34495e;
        }

    .type-badge {
        display: inline-block;
        padding: 0.35rem 1rem;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .type-inbound {
        background: rgba(76, 201, 240, 0.15);
        color: #0096c7;
    }

    .type-outbound {
        background: rgba(247, 37, 133, 0.15);
        color: #f72585;
    }

    .btn-view {
        border-radius: 50px;
        padding: 0.4rem 1.2rem;
        font-size: 0.9rem;
        font-weight: 500;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

        .btn-view:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
            color: white;
        }

    .badge-reference {
        background: #e9ecef;
        color: #495057;
        padding: 0.25rem 0.75rem;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
    }

    .empty-state {
        text-align: center;
        padding: 3rem;
        color: #95a5a6;
    }

        .empty-state i {
            font-size: 4rem;
            margin-bottom: 1rem;
            color: #dcdde1;
        }

    .date-display {
        display: flex;
        flex-direction: column;
    }

    .date-main {
        font-weight: 600;
        color: #2c3e50;
    }

    .date-sub {
        font-size: 0.8rem;
        color: #95a5a6;
    }

    /* Animations */
    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animated-item {
        animation: slideIn 0.5s ease forwards;
        opacity: 0;
    }

    .delay-1 {
        animation-delay: 0.1s;
    }

    .delay-2 {
        animation-delay: 0.2s;
    }

    .delay-3 {
        animation-delay: 0.3s;
    }
</style>

<div class="container-fluid py-4">
    <!-- Profile Header -->
    <div class="profile-header p-4 animated-item">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div class="d-flex align-items-center gap-4">
                <div class="profile-avatar">
                    <i class="bi bi-person-circle"></i>
                </div>
                <div>
                    <h1 class="profile-title">@Model.ClientName</h1>
                    <div class="profile-subtitle">
                        <i class="bi bi-person-badge me-1"></i>
                        Client ID: @Model.ClientId
                    </div>
                </div>
            </div>
            <div>
                <a asp-action="Index" class="btn-back">
                    <i class="bi bi-arrow-left me-1"></i>
                    Back to Accounts
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column - Contact Info & Stats -->
        <div class="col-lg-4">
            <!-- Contact Information Card -->
            <div class="info-card mb-4 animated-item delay-1">
                <div class="info-card-header">
                    <h6>
                        <i class="bi bi-info-circle"></i>
                        Contact Information
                    </h6>
                </div>
                <div class="info-card-body">
                    <div class="info-item">
                        <span class="info-item-label">
                            <i class="bi bi-geo-alt me-1"></i>Address:
                        </span>
                        <span class="info-item-value">
                            @if (!string.IsNullOrEmpty(Model.Address))
                            {
                                @Model.Address
                            }
                            else
                            {
                                <span class="text-muted">Not provided</span>
                            }
                        </span>
                    </div>
                    <div class="info-item">
                        <span class="info-item-label">
                            <i class="bi bi-telephone me-1"></i>Phone:
                        </span>
                        <span class="info-item-value">
                            @if (Model.PhoneNumber ==0)
                            {
                                @Model.PhoneNumber
                            }
                            else
                            {
                                <span class="text-muted">Not provided</span>
                            }
                        </span>
                    </div>
                </div>
            </div>

            <!-- Statistics Card -->
            <div class="stats-card animated-item delay-2">
                <div class="stats-card-header">
                    <h6>
                        <i class="bi bi-pie-chart"></i>
                        Inventory Summary
                    </h6>
                </div>
                <div class="stats-card-body">
                    <div class="stat-row">
                        <span class="stat-row-label">
                            <i class="bi bi-arrow-down-circle text-info"></i>
                            Inbound Cartons
                        </span>
                        <span class="stat-row-value">@Model.Totals.TotalInboundCartons.ToString("N0")</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-row-label">
                            <i class="bi bi-arrow-down-circle-fill text-info"></i>
                            Inbound Pallets
                        </span>
                        <span class="stat-row-value">@Model.Totals.TotalInboundPallets.ToString("N0")</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-row-label">
                            <i class="bi bi-arrow-up-circle text-danger"></i>
                            Outbound Cartons
                        </span>
                        <span class="stat-row-value">@Model.Totals.TotalOutboundCartons.ToString("N0")</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-row-label">
                            <i class="bi bi-arrow-up-circle-fill text-danger"></i>
                            Outbound Pallets
                        </span>
                        <span class="stat-row-value">@Model.Totals.TotalOutboundPallets.ToString("N0")</span>
                    </div>

                    <div class="stat-row total">
                        <span class="stat-row-label">
                            <i class="bi bi-box text-primary"></i>
                            Net Cartons
                        </span>
                        <span class="stat-row-value @(Model.Totals.NetCartons >= 0 ? "text-success" : "text-danger")">
                            @Model.Totals.NetCartons.ToString("N0")
                        </span>
                    </div>
                    <div class="stat-row total">
                        <span class="stat-row-label">
                            <i class="bi bi-box-seam text-primary"></i>
                            Net Pallets
                        </span>
                        <span class="stat-row-value @(Model.Totals.NetPallets >= 0 ? "text-success" : "text-danger")">
                            @Model.Totals.NetPallets.ToString("N0")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column - Transactions -->
        <div class="col-lg-8">
            <div class="transactions-card animated-item delay-3">
                <div class="transactions-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h6>
                            <i class="bi bi-clock-history"></i>
                            Transaction History
                            <span class="badge bg-light text-dark ms-2">@Model.Transactions.Count()</span>
                        </h6>
                        <div class="d-flex gap-2">
                            <select class="form-select form-select-sm" style="width: auto; background: rgba(255,255,255,0.2); color: white; border: none;">
                                <option value="all" selected>All</option>
                                <option value="inbound">Inbound</option>
                                <option value="outbound">Outbound</option>
                            </select>
                        </div>
                    </div>
                </div>

                @if (!Model.Transactions.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-inbox"></i>
                        <h5>No Transactions Found</h5>
                        <p class="text-muted">There are no transactions for this client yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-custom" id="transactionsTable">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Date & Time</th>
                                    <th class="text-end">Cartons</th>
                                    <th class="text-end">Pallets</th>
                                    <th>Reference</th>
                                    <th>Notes</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.Transactions)
                                {
                                    <tr>
                                        <td>
                                            <span class="type-badge @(t.Type == "Inbound" ? "type-inbound" : "type-outbound")">
                                                <i class="bi bi-arrow-@(t.Type == "Inbound" ? "down" : "up")-circle-fill me-1"></i>
                                                @t.Type
                                            </span>
                                        </td>
                                        <td>
                                            <div class="date-display">
                                                <span class="date-main">@t.Date.ToLocalTime().ToString("MMM dd, yyyy")</span>
                                                <span class="date-sub">@t.Date.ToLocalTime().ToString("hh:mm tt")</span>
                                            </div>
                                        </td>
                                        <td class="text-end fw-bold">@t.Cartons.ToString("N0")</td>
                                        <td class="text-end fw-bold">@t.Pallets.ToString("N0")</td>
                                        <td>
                                            @if (t.AdditionalEntry ==0)
                                            {
                                                <span class="badge-reference">
                                                    <i class="bi bi-tag me-1"></i>
                                                    @t.AdditionalEntry
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(t.Notes))
                                            {
                                                <span title="@t.Notes" style="cursor: help;">
                                                    @(t.Notes.Length > 20 ? t.Notes.Substring(0, 20) + "..." : t.Notes)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (t.Type == "Inbound")
                                            {
                                                <a class="btn-view"
                                                   asp-controller="Inbound"
                                                   asp-action="Details"
                                                   asp-route-id="@t.TransactionId">
                                                    <i class="bi bi-eye-fill me-1"></i> View
                                                </a>
                                            }
                                            else
                                            {
                                                <a class="btn-view"
                                                   asp-controller="Outbound"
                                                   asp-action="Details"
                                                   asp-route-id="@t.TransactionId">
                                                    <i class="bi bi-eye-fill me-1"></i> View
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Filter functionality for transactions
        document.querySelector('select')?.addEventListener('change', function(e) {
            const filter = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('#transactionsTable tbody tr');

            rows.forEach(row => {
                const typeCell = row.querySelector('.type-badge');
                if (!typeCell) return;

                const type = typeCell.innerText.trim().toLowerCase();

                if (filter === 'all') {
                    row.style.display = '';
                } else if (filter === 'inbound' && type.includes('inbound')) {
                    row.style.display = '';
                } else if (filter === 'outbound' && type.includes('outbound')) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });

            // Show/hide empty message
            const tbody = document.querySelector('#transactionsTable tbody');
            const visibleRows = Array.from(rows).filter(r => r.style.display !== 'none');

            if (visibleRows.length === 0) {
                // You could show a message here
            }
        });

        // Animation on scroll
        document.addEventListener('DOMContentLoaded', function() {
            const elements = document.querySelectorAll('.animated-item');

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                    }
                });
            }, { threshold: 0.1 });

            elements.forEach(element => {
                observer.observe(element);
            });
        });
    </script>
}