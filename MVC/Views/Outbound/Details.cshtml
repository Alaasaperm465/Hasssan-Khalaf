@model MVC.ViewModels.Outbound.OutboundDetailsVM
@{
    ViewData["Title"] = "?????? ????????";
}

<style>
    /* reuse styles from Inbound details for consistency */
    .no-print { }
</style>

<div class="container mt-4">
    <div class="card p-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4>??? ?????? #@Model.Id</h4>
            <div>
                <button id="printBtn" class="btn btn-outline-secondary no-print">???? ?????</button>
            </div>
        </div>

        <div class="mb-3 text-muted">
            <div><strong>??????:</strong> @Model.ClientName</div>
            <div><strong>????? ???????:</strong> @Model.CreatedAt.ToLocalTime().ToString("g")</div>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>??????</th>
                        <th>??????</th>
                        <th class="text-end">???????</th>
                        <th class="text-end">????????</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var d in Model.Details)
                    {
                        <tr>
                            <td>@(d.ProductName ?? d.ProductId.ToString())</td>
                            <td>@(d.SectionName ?? d.SectionId.ToString())</td>
                            <td class="text-end">@d.Cartons</td>
                            <td class="text-end">@d.Pallets</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="2">????????</th>
                        <th class="text-end">@Model.TotalCartons</th>
                        <th class="text-end">@Model.TotalPallets</th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="mt-3 no-print">
            <a class="btn btn-secondary" asp-action="Index">????</a>
        </div>
    </div>
</div>

<script>
    document.getElementById('printBtn').addEventListener('click', function(){ window.print(); });
</script>
